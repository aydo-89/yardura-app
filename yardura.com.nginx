# HTTPS server for www.yardura.com (proxied to Next.js)
server {
    server_name www.yardura.com;

    # Reverse proxy to Next.js app
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Content-Security-Policy "default-src 'self' http: https: data: blob: 'unsafe-inline'" always;

    # HSTS Header - Force HTTPS for 1 year
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    # Security - hide nginx version
    server_tokens off;

    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/yardura.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/yardura.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

# Redirect naked domain to www (HTTPS)
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name yardura.com;

    ssl_certificate /etc/letsencrypt/live/yardura.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/yardura.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    return 301 https://www.yardura.com$request_uri;
}

# Redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;

    server_name yardura.com www.yardura.com;

    # Immediate redirect to HTTPS www
    return 301 https://www.yardura.com$request_uri;
}
